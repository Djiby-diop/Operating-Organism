	$(SRC_ROOT)/engine/ssm/soma_meta.c \
	$(SRC_ROOT)/engine/ssm/soma_reflex.c \
	$(SRC_ROOT)/engine/ssm/soma_router.c \
	$(SRC_ROOT)/engine/ssm/soma_session.c \
	$(SRC_ROOT)/engine/ssm/soma_smb.c \
	$(SRC_ROOT)/engine/ssm/soma_spec.c \
	$(SRC_ROOT)/engine/ssm/soma_swarm.c \
	$(SRC_ROOT)/engine/ssm/soma_swarm_net.c \
	$(SRC_ROOT)/engine/ssm/soma_warden.c \
	$(SRC_ROOT)/engine/ssm/oosi_infer.c \
	$(SRC_ROOT)/engine/ssm/oosi_loader.c \
	$(SRC_ROOT)/engine/ssm/oosi_v3_infer.c \
	$(SRC_ROOT)/engine/ssm/oosi_v3_loader.c \
	$(SRC_ROOT)/engine/djiblas/djiblas.c \
	$(SRC_ROOT)/engine/gguf/gguf_loader.c \
	$(SRC_ROOT)/core/llmk_oo.c \
	$(SRC_ROOT)/core/llmk_oo_infer.c \
	$(SRC_ROOT)/core/llmk_log.c \
	$(SRC_ROOT)/core/llmk_sentinel.c \
	$(SRC_ROOT)/core/llmk_zones.c \
	$(SRC_ROOT)/core/llmk_stubs.c

# attention_avx2.c needs -mavx2/-mfma (separate compile rule)
OO_SRC_AVX2_SRCS = $(SRC_ROOT)/engine/ssm/attention_avx2.c

OO_SRC_ENGINE_OBJS = $(patsubst $(SRC_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_SRC_ENGINE_SRCS))
OO_SRC_AVX2_OBJS   = $(patsubst $(SRC_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_SRC_AVX2_SRCS))

OO_KERNEL_OBJS  = $(patsubst $(OO_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_KERNEL_SRCS))
OO_WARDEN_OBJS  = $(patsubst $(OO_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_WARDEN_SRCS))
OO_ENGINE_OBJS  = $(patsubst $(OO_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_ENGINE_SRCS))
OO_MODULES_OBJS = $(patsubst $(OO_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_MODULES_SRCS))
OO_BUS_OBJS     = $(patsubst $(OO_ROOT)/%.c,$(OO_BUILD)/%.o,$(OO_BUS_SRCS))

.PHONY: all clean

all: $(OO_BUILD)/liboo-kernel.a $(OO_BUILD)/liboo-warden.a \
	$(OO_BUILD)/liboo-engine.a $(OO_BUILD)/liboo-modules.a \
	$(OO_BUILD)/liboo-bus.a $(OO_BUILD)/librust_guard.a
	@echo 
	@echo === OO BUILD COMPLETE ===
	@ls -lh $(OO_BUILD)/*.a

$(OO_BUILD)/liboo-kernel.a: $(OO_KERNEL_OBJS)
	@mkdir -p $(dir $@)
	$(AR) rcs $@ $^
	@echo [AR] $@

$(OO_BUILD)/liboo-warden.a: $(OO_WARDEN_OBJS)
	@mkdir -p $(dir $@)
	$(AR) rcs $@ $^
	@echo [AR] $@

$(OO_BUILD)/liboo-engine.a: $(OO_ENGINE_OBJS) $(OO_SRC_ENGINE_OBJS) $(OO_SRC_AVX2_OBJS)
	@mkdir -p $(dir $@)
	$(AR) rcs $@ $^
	@echo [AR] $@

$(OO_BUILD)/liboo-modules.a: $(OO_MODULES_OBJS)
	@mkdir -p $(dir $@)
	$(AR) rcs $@ $^
	@echo [AR] $@

$(OO_BUILD)/liboo-bus.a: $(OO_BUS_OBJS)
	@mkdir -p $(dir $@)
	$(AR) rcs $@ $^
	@echo [AR] $@

# Rust guard static library (no_std, C-ABI, panic=abort)
$(OO_BUILD)/librust_guard.a: $(GUARD_DIR)/Cargo.toml $(GUARD_DIR)/libguard/src/ffi.rs
	@mkdir -p $(OO_BUILD)
	@echo "[CARGO] Building libguard..."
	cd $(GUARD_DIR) && cargo build --release -p libguard 2>&1 | grep -v '^warning: profiles'
	cp $(GUARD_DIR)/target/release/librust_guard.a $(OO_BUILD)/librust_guard.a
	@echo [AR] $(OO_BUILD)/librust_guard.a

$(OO_BUILD)/%.o: $(OO_ROOT)/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

# Compile rules for SRC_ROOT real implementations
$(OO_BUILD)/oo-modules/%.o: $(SRC_ROOT)/oo-modules/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -I$(dir $<) -c $< -o $@

$(OO_BUILD)/engine/ssm/attention_avx2.o: $(SRC_ROOT)/engine/ssm/attention_avx2.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -mavx2 -mfma -I$(SRC_ROOT)/engine/ssm -c $< -o $@

$(OO_BUILD)/engine/ssm/%.o: $(SRC_ROOT)/engine/ssm/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -I$(SRC_ROOT)/engine/ssm -I$(SRC_ROOT)/engine/ssm/core -c $< -o $@

$(OO_BUILD)/engine/djiblas/%.o: $(SRC_ROOT)/engine/djiblas/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

$(OO_BUILD)/engine/gguf/%.o: $(SRC_ROOT)/engine/gguf/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

$(OO_BUILD)/oo-bus/%.o: $(SRC_ROOT)/oo-bus/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

$(OO_BUILD)/core/%.o: $(SRC_ROOT)/core/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

# efi_phases.c unity-includes llama2_efi_final.c — always rebuild (WSL/NTFS timestamps unreliable)
.PHONY: oo_efi_phases_force
$(OO_BUILD)/oo-kernel/boot/efi_phases.o: $(SRC_ROOT)/llama2_efi_final.c $(METABION_PROFILE_HDR) oo_efi_phases_force

clean:
	rm -rf $(OO_BUILD)
	cd $(GUARD_DIR) && cargo clean




# ============================================================
# EFI Link Step -- produce KERNEL.EFI from all archives
# ============================================================
EFI_CRT0    := /usr/lib/crt0-efi-x86_64.o
EFI_LIB_DIR := /usr/lib
KERNEL_SO   := $(OO_BUILD)/kernel.so
KERNEL_EFI  := $(OO_ROOT)/KERNEL.EFI

EFI_LIBS    := -L$(EFI_LIB_DIR) -lefi -lgnuefi
LDFLAGS_EFI := -nostdlib -shared -Wl,-Bsymbolic -T $(EFI_LDS) $(EFI_CRT0)

.PHONY: efi inject-efi

efi: $(KERNEL_EFI)

$(KERNEL_EFI): $(KERNEL_SO)
	@echo "[OBJCOPY] $@"
	objcopy -j .text -j .sdata -j .data -j .dynamic -j .dynsym -j .rel -j .rela -j .rela.dyn -j .reloc --target=efi-app-x86_64 $(KERNEL_SO) $@
	@ls -lh $@

$(KERNEL_SO): $(OO_BUILD)/liboo-kernel.a $(OO_BUILD)/liboo-warden.a $(OO_BUILD)/liboo-engine.a $(OO_BUILD)/liboo-modules.a $(OO_BUILD)/liboo-bus.a $(OO_BUILD)/librust_guard.a
	@mkdir -p $(dir $@)
	@echo "[LINK] $@"
	gcc $(LDFLAGS_EFI) -Wl,--whole-archive $(OO_BUILD)/liboo-kernel.a $(OO_BUILD)/liboo-warden.a $(OO_BUILD)/liboo-engine.a $(OO_BUILD)/liboo-modules.a $(OO_BUILD)/liboo-bus.a -Wl,--no-whole-archive $(OO_BUILD)/librust_guard.a $(EFI_LIBS) -o $@

inject-efi: $(KERNEL_EFI)
	@BOOT="$(OO_ROOT)/llm-baremetal-boot.img"; [ -f "$$BOOT" ] || BOOT="$(SRC_ROOT)/../llm-baremetal-boot.img"; if [ -f "$$BOOT" ]; then mcopy -oi "$$BOOT@@1048576" $< z:/KERNEL.EFI && echo "[INJECT] done"; else echo "[INJECT] no boot image"; fi
