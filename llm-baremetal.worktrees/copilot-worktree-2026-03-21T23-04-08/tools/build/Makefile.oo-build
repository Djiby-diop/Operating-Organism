	$(OO_ROOT)/evolvion-engine/core/stub_asm.c

OO_MODULES_SRCS = \
	$(OO_ROOT)/oo-modules/module_api.c \
	$(OO_ROOT)/oo-modules/sensing/conscience/module_conscience.c \
	$(OO_ROOT)/oo-modules/sensing/compatibilion/module_compatibilion.c \
	$(OO_ROOT)/oo-modules/sensing/diagnostion/module_diagnostion.c \
	$(OO_ROOT)/oo-modules/sensing/metabion/module_metabion.c \
	$(OO_ROOT)/oo-modules/adaptation/calibrion/module_calibrion.c \
	$(OO_ROOT)/oo-modules/adaptation/diopion/module_diopion.c \
	$(OO_ROOT)/oo-modules/adaptation/morphion/module_morphion.c \
	$(OO_ROOT)/oo-modules/adaptation/symbion/module_symbion.c \
	$(OO_ROOT)/oo-modules/adaptation/evolvion/module_evolvion.c \
	$(OO_ROOT)/oo-modules/memory/memorion/module_memorion.c \
