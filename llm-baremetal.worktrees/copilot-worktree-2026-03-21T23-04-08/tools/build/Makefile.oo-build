# Makefile.oo-build -- OO subsystem build validation
# Usage (WSL from worktree root): make -f tools/build/Makefile.oo-build -j4
ARCH = x86_64
CC   = gcc
AR   = ar
OO_ROOT  ?= .
SRC_ROOT ?= ../../llm-baremetal
GUARD_DIR = $(OO_ROOT)/oo-warden/guard
MULTIARCH := $(shell $(CC) -print-multiarch 2>/dev/null)
EFI_LIBDIR_CANDS := /usr/lib /usr/lib/$(MULTIARCH)
EFI_LDS := $(firstword $(wildcard $(addsuffix /elf_$(ARCH)_efi.lds,$(EFI_LIBDIR_CANDS))))
EFI_INCLUDES = -I/usr/include/efi -I/usr/include/efi/$(ARCH)

CFLAGS = \
	-ffreestanding -fno-stack-protector -fpic -fshort-wchar -mno-red-zone \
	$(EFI_INCLUDES) -DEFI_FUNCTION_WRAPPER -DUEFI_BUILD \
-I$(SRC_ROOT)/engine/ssm -I$(SRC_ROOT)/engine/gguf -I$(SRC_ROOT)/engine/djiblas \
-I$(SRC_ROOT)/core -I$(OO_ROOT) -I$(SRC_ROOT) \
	-O2 -msse2 -DDJIBLAS_DISABLE_CPUID=1 \
	-Wall -Wno-unused-parameter -Wno-unused-function

# Phase 5 (best-effort): ensure metabion_profile.h exists for unity-includes.
METABION_PROFILE_HDR = $(SRC_ROOT)/metabion_profile.h
METABION_PROFILE_DEFAULT = $(SRC_ROOT)/metabion_profile_default.h

$(METABION_PROFILE_HDR): $(METABION_PROFILE_DEFAULT)
	@if [ -f "$@" ]; then :; else cp "$<" "$@"; echo "OK: using metabion_profile.h fallback (default)"; fi

OO_BUILD = $(OO_ROOT)/build/oo

OO_KERNEL_SRCS = \
	$(OO_ROOT)/oo-kernel/hal/hw_dna.c \
	$(OO_ROOT)/oo-kernel/hal/pmu.c \
	$(OO_ROOT)/oo-kernel/hal/ui_overlay.c \
	$(OO_ROOT)/oo-kernel/hal/ui_splash.c \
	$(OO_ROOT)/oo-kernel/mem/heap.c \
	$(OO_ROOT)/oo-kernel/boot/oo_boot.c \
	$(OO_ROOT)/oo-kernel/boot/efi_entry.c \
	$(OO_ROOT)/oo-kernel/boot/efi_phases.c \
	$(OO_ROOT)/oo-kernel/boot/oo_globals.c \
	$(OO_ROOT)/oo-kernel/boot/oo_weak_stubs.c \
	$(OO_ROOT)/oo-kernel/repl/oo_repl.c \
	$(OO_ROOT)/oo-kernel/repl/repl.c \
	$(OO_ROOT)/oo-kernel/repl/repl_ctx.c

OO_WARDEN_SRCS = \
	$(OO_ROOT)/oo-warden/sentinel/pressure.c \
	$(OO_ROOT)/oo-warden/dplus/dplus.c \
	$(OO_ROOT)/oo-warden/recovery/orchestrator.c

OO_ENGINE_SRCS = \
	$(OO_ROOT)/oo-engine/kv_persist/kv_persist.c \
	$(OO_ROOT)/oo-engine/blas/hebbian.c \
	$(OO_ROOT)/oo-engine/splitbrain/splitbrain.c \
	$(OO_ROOT)/oo-engine/journal_train/journal_train.c \
	$(OO_ROOT)/dreamion-engine/core/dreamion.c \
	$(OO_ROOT)/ghost-engine/core/ghost.c \
