	$(SRC_ROOT)/oo-modules/cellion-engine/core/cellion.c \
	$(SRC_ROOT)/oo-modules/collectivion-engine/core/collectivion.c \
	$(SRC_ROOT)/oo-modules/compatibilion-engine/core/compatibilion.c \
	$(SRC_ROOT)/oo-modules/conscience-engine/core/conscience.c \
	$(SRC_ROOT)/oo-modules/diagnostion-engine/core/diagnostion.c \
	$(SRC_ROOT)/oo-modules/diopion-engine/core/diopion.c \
	$(SRC_ROOT)/oo-modules/djibion-engine/core/djibion.c \
	$(SRC_ROOT)/oo-modules/dreamion-engine/core/dreamion.c \
	$(SRC_ROOT)/oo-modules/evolvion-engine/core/evolvion.c \
	$(SRC_ROOT)/oo-modules/ghost-engine/core/ghost.c \
	$(SRC_ROOT)/oo-modules/immunion-engine/core/immunion.c \
	$(SRC_ROOT)/oo-modules/memorion-engine/core/memorion.c \
	$(SRC_ROOT)/oo-modules/metabion-engine/core/metabion.c \
	$(SRC_ROOT)/oo-modules/morphion-engine/core/morphion.c \
	$(SRC_ROOT)/oo-modules/neuralfs-engine/core/neuralfs.c \
	$(SRC_ROOT)/oo-modules/orchestrion-engine/core/orchestrion.c \
	$(SRC_ROOT)/oo-modules/pheromion-engine/core/pheromion.c \
	$(SRC_ROOT)/oo-modules/symbion-engine/core/symbion.c \
	$(SRC_ROOT)/oo-modules/synaption-engine/core/synaption.c \
	$(SRC_ROOT)/oo-modules/wasm-engine/core/oo_wasm.c \
