	$(OO_ROOT)/oo-kernel/hal/cmd_dna.c \
	$(OO_ROOT)/oo-warden/sentinel/cmd_pressure.c \
	$(OO_ROOT)/oo-engine/splitbrain/cmd_splitbrain.c \
	$(OO_ROOT)/oo-engine/blas/cmd_hebbian.c \
	$(OO_ROOT)/oo-engine/kv_persist/cmd_kv_persist.c \
	$(OO_ROOT)/oo-modules/memory/pheromion/cmd_pheromion.c \
	$(OO_ROOT)/oo-modules/sensing/conscience/cmd_conscience.c \
